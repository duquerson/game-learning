{
  "name": "microlearn-astro-vue",
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:security": "vitest tests/security --reporter=verbose",
    "test:security:coverage": "vitest tests/security --coverage",
    "test:sql-injection": "vitest tests/security/owasp-sql-injection-audit.test.ts --reporter=verbose",
    "test:tampering": "vitest tests/security/submission-tampering.security.test.ts --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:visual-a11y": "playwright test --project=simple visual-and-accessibility.spec.ts",
    "test:visual-a11y:full": "playwright test visual-and-accessibility.spec.ts",
    "test:visual-a11y:ui": "playwright test --project=simple visual-and-accessibility.spec.ts --ui",
    "test:visual-a11y:update": "playwright test --project=simple visual-and-accessibility.spec.ts --update-snapshots",
    "test:visual-a11y:simple": "playwright test --project=simple visual-a11y-simple.spec.ts",
    "test:visual-a11y:simple:ui": "playwright test --project=simple visual-a11y-simple.spec.ts --ui",
    "lint": "eslint src tests",
    "type-check": "tsc --noEmit",
    "security:audit": "npm audit --production && npm run test:security"
  },
  "dependencies": {
    "@astrojs/vercel": "^10.0.2",
    "@astrojs/vue": "^6.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.39.0",
    "astro": "^6.1.6",
    "canvas-confetti": "^1.9.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.3",
    "fast-check": "^4.7.0",
    "tailwindcss": "^4.0.0",
    "vitest": "^4.1.5"
  }
}

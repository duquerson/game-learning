---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/layout/Sidebar.vue";
import BottomNav from "../components/layout/BottomNav.vue";
import ToasterWrapper from "../components/ui/ToasterWrapper.vue";
import AuthInitializer from "../components/AuthInitializer.vue";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <!-- Sidebar: hidden on mobile, visible on ≥768px (R13.3) -->
    <div class="hidden md:flex">
      <Sidebar client:idle />
    </div>

    <!-- Main content -->
    <main
      class="flex-1 overflow-y-auto p-4 pb-20 md:p-6 md:pb-6 lg:p-8 lg:pb-8"
    >
      <slot />
    </main>
  </div>

  <!-- Bottom nav: visible on mobile <768px, hidden on ≥768px (R13.2) -->
  <div class="flex md:hidden">
    <BottomNav client:idle />
  </div>

  <!-- Root initializers -->
  <AuthInitializer client:idle />
  <ToasterWrapper client:idle />
</BaseLayout>

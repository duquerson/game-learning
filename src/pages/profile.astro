---
import AppLayout from '../layouts/AppLayout.astro'
import ProfileView from '../components/profile/ProfileView.vue'
import { createSupabaseServerClient } from '../lib/supabase'
import { createAppError, logServerError } from '../lib/errors'

const supabase = createSupabaseServerClient(Astro.cookies)
const { data: { user } } = await supabase.auth.getUser()
if (!user) return Astro.redirect('/login')

// Leer user_stats (R12.1, R12.2)
const { data: statsData, error: statsError } = await supabase
  .from('user_stats')
  .select('total_points, current_streak, longest_streak')
  .eq('user_id', user.id)
  .maybeSingle()

if (statsError) {
  const appErr = createAppError('INTERNAL_ERROR', statsError.message, '/profile')
  logServerError(appErr)
}

// Leer user_preferences (R2.6, R12.6)
const { data: prefsData, error: prefsError } = await supabase
  .from('user_preferences')
  .select('selected_topics')
  .eq('user_id', user.id)
  .maybeSingle()

if (prefsError) {
  const appErr = createAppError('INTERNAL_ERROR', prefsError.message, '/profile')
  logServerError(appErr)
}

// Calcular total repasadas y total correctas desde user_progress (R12.3, R12.4)
const { data: progressData, error: progressError } = await supabase
  .from('user_progress')
  .select('correct')
  .eq('user_id', user.id)

if (progressError) {
  const appErr = createAppError('INTERNAL_ERROR', progressError.message, '/profile')
  logServerError(appErr)
}

const totalReviewed = progressData?.length ?? 0
const totalCorrect = progressData?.filter(p => p.correct).length ?? 0

// Calcular porcentaje global de aciertos (R12.5)
const accuracyPercent = totalReviewed > 0
  ? Math.round((totalCorrect / totalReviewed) * 100)
  : 0

// Obtener topics disponibles desde cards (distinct)
const { data: topicsData } = await supabase
  .from('cards')
  .select('topic')

const availableTopics = [...new Set((topicsData ?? []).map((c: any) => c.topic as string))].sort()
---

<AppLayout title="Perfil">
  <ProfileView
    client:idle
    email={user.email ?? ''}
    totalPoints={statsData?.total_points ?? 0}
    currentStreak={statsData?.current_streak ?? 0}
    longestStreak={statsData?.longest_streak ?? 0}
    totalReviewed={totalReviewed}
    totalCorrect={totalCorrect}
    accuracyPercent={accuracyPercent}
    selectedTopics={prefsData?.selected_topics ?? []}
    availableTopics={availableTopics}
  />
</AppLayout>

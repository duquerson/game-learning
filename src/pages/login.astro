---
import BaseLayout from '../layouts/BaseLayout.astro'
import LoginForm from '../components/auth/LoginForm.vue'
---

<BaseLayout title="Login">
  <main class="auth-page">
    <LoginForm client:load />
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
</style>